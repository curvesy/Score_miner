.ruff_cache/
.pyright/

# Virtual environments and local env
.venv/
venv/
env/
.env
.env.*

# Build/package artifacts
build/
dist/
*.egg-info/
*.whl

# Runtime/output artifacts
runs/
artifacts/
.cache/
*.jsonl
*.parquet

# Local training/review data. These are reproducible or large and should not be committed.
public_detect/data/external/
public_detect/data/raw/
public_detect/data/proof_frames/**
