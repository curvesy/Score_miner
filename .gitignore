public_detect/data/yolo_candidates/
public_detect/reports/source_reviews/
public_detect/reports/failure_reviews/**/crops/
public_detect/reports/failure_reviews/**/full/
public_detect/reports/label_previews/
public_detect/**/*.jpg
public_detect/**/*.jpeg
public_detect/**/*.png
public_detect/**/*.webp
public_detect/**/*.gif

# Models and large binaries
models/
datasets/
*.pt
*.pth
*.onnx
*.engine
*.trt
*.mp4
*.mov
*.avi
*.mkv

